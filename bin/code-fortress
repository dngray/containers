#!/bin/bash
# ~/bin/code-fortress

# 1. Identity & Context Resolution
RAW_PATH=${1:-"$HOME/src"}
FORTRESS_PATH=$(realpath "$RAW_PATH") || exit 1
export FORTRESS_PATH
PROJECT_ID=$(basename "$FORTRESS_PATH")
export POD_NAME="ai-fortress-pod-$PROJECT_ID"
MODE=${2:-"opencode"}

# Validate operation mode immediately to fail fast
case "$MODE" in
"aider" | "opencode" | "goose") ;;
*)
  echo "❌ Usage: code-fortress <path> [aider|opencode|goose]"
  exit 1
  ;;
esac

# 2. Strict Context-Aware Cleanup
cleanup_fortress() {
  echo -e "\n🛡️  Dismantling Fortress components for $PROJECT_ID..."
  # Terminate the core pod container structure
  podman pod rm -f -t 0 "$POD_NAME" 2>/dev/null

  # Clean up orphaned containers explicitly belonging ONLY to this project context
  podman ps -a --filter "name=ai-fortress-.*-$PROJECT_ID" --format "{{.ID}}" | xargs -r podman rm -f -t 0 >/dev/null 2>&1
  echo "🏰 Gates closed."
}

# Bind trap to multiple termination signals to guarantee cleanup if Zellij dies abruptly
trap cleanup_fortress EXIT INT TERM

# 3. Infrastructure Prep
echo "🏗️  Purging old instances for $POD_NAME..."
podman pod rm -f -t 0 "$POD_NAME" 2>/dev/null

echo "🏗️  Initializing Fortress Pod (Shared Mode): $POD_NAME"
podman pod create \
  --name "$POD_NAME" \
  --share net \
  --userns keep-id \
  --network bridge \
  -p 127.0.0.1:4096:4096/tcp \
  -p 127.0.0.1:5005:5005/tcp

# 4. Secrets Fetching
echo "🔑 Unlocking fortress credentials..."
export OPENCODE_SERVER_USERNAME="opencode"
OPENCODE_SERVER_PASSWORD=$(gopass show ai/opencode-server-pass) || exit 1
OPENROUTER_API_KEY=$(gopass show ai/openrouter-api-key) || exit 1
OPENAI_API_KEY=$(gopass show ai/openai-api-key) || exit 1
ANTHROPIC_API_KEY=$(gopass show ai/anthropic-api-key) || exit 1
export OPENCODE_SERVER_PASSWORD OPENROUTER_API_KEY OPENAI_API_KEY ANTHROPIC_API_KEY

export GOGOOSE_MODE="${GOOSE_MODE:-nanogpt}"

# 5. Execution Environment Launch
echo "🏰 Fortifying workspace in $MODE mode at: $FORTRESS_PATH"
zellij --layout "$CONTAINER_REPO_PATH/layouts/${MODE}-fortress.kdl"
