policy_module(container_aerc, 1.0.0)

gen_require(`
    type container_runtime_t;
    type container_t;
    type pasta_t;
    type home_bin_t;
    type user_tmp_t;
    type session_dbusd_tmp_t;
    type unconfined_t;
    type unconfined_dbusd_t;
    type container_file_t;
    type cgroup_t;
    type devtty_t;
    type proc_t;
    type gconf_home_t;
    type config_home_t;
    type cpu_online_t;
    type data_home_t;
    type gpg_secret_t;
    role system_r;

    class process { transition dyntransition fork signal signull sigkill getattr setkeycreate setsched noatsecure rlimitinh siginh execmem };
    class dir { read write add_name remove_name getattr search watch setattr create open };
    class file { read write execute open getattr link unlink create append map rename lock execute_no_trans setattr ioctl };
    class lnk_file { read write create unlink getattr };
    class sock_file { read write create open getattr setattr unlink };
    class unix_stream_socket { connectto read write };
    class dbus { send_msg };
    class tcp_socket { create connect write read name_connect bind listen accept };
    class key { create };
    class cap_userns { dac_override dac_read_search };
    class fifo_file { write read open getattr create unlink };
')

# Define custom container execution domain
type aerc_t;
role system_r types aerc_t;
virt_sandbox_domain(aerc_t)

# Define dedicated mail data label type
type aerc_data_t;
files_type(aerc_data_t)

###########################################
# ⚙️ Host & Runtime Service Management
###########################################
allow container_runtime_t aerc_t:process { transition noatsecure rlimitinh siginh signal signull sigkill getattr };
allow container_runtime_t aerc_t:dir { search read open getattr };
allow container_runtime_t aerc_t:file { read open getattr };
allow container_runtime_t aerc_t:key { create };
allow container_runtime_t aerc_t:lnk_file { read getattr };
allow unconfined_t aerc_t:dir { search read getattr open };
allow unconfined_t aerc_t:process { signal signull sigkill };

# Self-managed process lifecycle
allow aerc_t self:process { setkeycreate setsched transition dyntransition fork signal signull sigkill getattr execmem };
allow aerc_t self:dir { search read open getattr };
allow aerc_t self:file { read write open getattr };
allow aerc_t self:lnk_file { read getattr };
allow aerc_t self:fifo_file { read write open getattr create unlink };
allow aerc_t self:fd use;
allow aerc_t self:tcp_socket { create connect write read bind listen accept };

allow aerc_t container_runtime_t:fd use;
allow aerc_t container_runtime_t:fifo_file { read write open getattr ioctl };
allow pasta_t self:cap_userns { dac_override dac_read_search };

# Mail data storage
allow aerc_t aerc_data_t:dir { read write getattr search watch add_name remove_name setattr create };
allow aerc_t aerc_data_t:file { open read write getattr execute append create map rename unlink link lock setattr ioctl };
allow aerc_t aerc_data_t:lnk_file { read write create unlink };

###########################################
# Reference policy interfaces
###########################################
dev_rw_null(aerc_t)
dev_read_rand(aerc_t)
dev_read_urand(aerc_t)
kernel_read_proc_symlinks(aerc_t)
kernel_read_system_state(aerc_t)
userdom_use_user_terminals(aerc_t)

# Mail Ports & Network Infrastructure Layer
sysnet_dns_name_resolve(aerc_t)
corenet_tcp_connect_pop_port(aerc_t)
corenet_tcp_connect_smtp_port(aerc_t)
corenet_tcp_connect_http_port(aerc_t)
corenet_tcp_bind_generic_node(aerc_t)
corenet_tcp_bind_all_unreserved_ports(aerc_t)
corenet_tcp_connect_all_unreserved_ports(aerc_t)

# Hardware SmartCard (YubiKey) Access via System Macro
pcscd_stream_connect(aerc_t)

# User home content
userdom_manage_user_home_content_dirs(aerc_t)
userdom_manage_user_home_content_files(aerc_t)

# Config file access (~/.config uses config_home_t on this distribution)
allow aerc_t config_home_t:dir { read getattr search open };
allow aerc_t config_home_t:file { open read getattr ioctl };

# Data home access (~/.local/share uses data_home_t on this distribution)
allow aerc_t data_home_t:dir { read write getattr search watch add_name remove_name setattr create open rmdir };
allow aerc_t data_home_t:file { read write getattr open create append link unlink rename lock setattr map execute };
allow aerc_t data_home_t:lnk_file { read write create unlink getattr };

# Container-internal script attachments (~/.local/bin)
allow aerc_t home_bin_t:file { open execute getattr read execute_no_trans };

# Allow mbsync lock files in ~/.local/state (Secureblue labels it gconf_home_t)
allow aerc_t gconf_home_t:dir { read write getattr search watch add_name remove_name setattr create open };
allow aerc_t gconf_home_t:file { read write getattr open create append link unlink rename lock setattr };

###########################################
# Host IPC / D-Bus / pinentry
###########################################
# Runtime environment access to mounted host tmpfs /run/user paths
allow aerc_t user_tmp_t:dir { read write open getattr search watch add_name remove_name create setattr };
allow aerc_t user_tmp_t:file { open read write getattr create append link unlink lock setattr };
allow aerc_t user_tmp_t:sock_file { read write create open getattr setattr unlink };

# Graphical Pinentry Password Box Popups & Session D-Bus routing
allow aerc_t session_dbusd_tmp_t:dir { search read getattr };
allow aerc_t session_dbusd_tmp_t:sock_file write;
allow aerc_t session_dbusd_tmp_t:unix_stream_socket connectto;
allow aerc_t unconfined_t:unix_stream_socket { connectto read write };
allow aerc_t unconfined_dbusd_t:unix_stream_socket connectto;
allow aerc_t unconfined_dbusd_t:dbus send_msg;

# 🔐 Host Keyring Vaults (~/.gnupg permissions)
allow aerc_t gpg_secret_t:dir { read write getattr search watch add_name remove_name setattr };
allow aerc_t gpg_secret_t:file { open read write getattr create append link unlink lock };
allow aerc_t gpg_secret_t:sock_file { read write create open getattr setattr unlink };
allow aerc_t gpg_secret_t:unix_stream_socket connectto;

dbus_stub(aerc_t)
unconfined_dbus_chat(aerc_t)
allow aerc_t unconfined_t:process { transition rlimitinh siginh noatsecure };

###########################################
# Terminal and system state
###########################################
allow aerc_t cgroup_t:file { read open getattr };
allow aerc_t proc_t:file { read open getattr };
allow aerc_t devtty_t:chr_file { read write open getattr ioctl };
allow aerc_t cpu_online_t:file { read open getattr };
